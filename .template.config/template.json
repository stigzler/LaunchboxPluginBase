{
  "$schema": "http://json.schemastore.org/template",
  "author": "stigzler",
  "classifications": [
    "LaunchBox",
    "Plugin"
  ],
  "identity": "Launchbox.Plugin.Template.CSharp",
  "name": "LaunchBox Plugin",
  "shortName": "launchbox-plugin",
  "sourceName": "LaunchboxPlugin",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "primaryOutputs": [
    {
      "path": "LaunchboxPlugin.slnx"
    }
  ],
  "postActions": [
    {
      "actionId": "D396686C-DE0E-4DE6-906D-291CD29FC5DE",
      "description": "Opens the solution in Visual Studio",
      "manualInstructions": [],
      "args": {
        "files": "0"
      },
      "continueOnError": true
    }
  ],
  "sources": [
    {
      "source": "./",
      "target": "./",
      "exclude": [
        ".template.config/**",
        ".git/**",
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
        "**/.vs/**",
        "**/*.user",
        "**/*.suo",
        "**/*.lock.json"
      ]
    }
  ],
  "symbols": {
    "LaunchBoxPluginsPath": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "C:/Users/YourUser/LaunchBox/Plugins",
      "replaces": "C:\\Users\\stigz\\LaunchBoxDevelopmentInstall\\Plugins",
      "displayName": "LaunchBox Plugins Path",
      "description": "The full path to your LaunchBox plugins directory (where the plugin will be copied after build)."
    }
  }
}